PORT=4000
MONGODB_URI=mongodb://localhost:27017/spendswise
JWT_SECRET=replace-with-a-long-random-string
CSRF_SECRET=replace-with-a-different-long-random-string
GOOGLE_CLIENT_ID=                          # get from Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_SECRET=                      # get from Google Cloud Console
GOOGLE_CALLBACK_URL=                       # default: http://localhost:5173/api/auth/google/callback
FRONTEND_URL=                              # default: http://localhost:5173 (must match Vite dev server or Vercel URL)
GROQ_API_KEY=                          # optional — enables AI features
GROQ_MODEL=llama-3.3-70b-versatile     # swap to any Groq model (e.g. openai/gpt-oss-20b)
GROQ_VISION_API_KEY=                   # optional — separate key for receipt vision (falls back to GROQ_API_KEY)
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_VISION_PRO_MODEL=qwen/qwen3.6-27b        # used for OCR Pro (costs 10 AI requests instead of 3)
AI_DAILY_LIMIT=50                      # max AI requests per user per day
AI_MONTHLY_LIMIT=500                   # max AI requests per user per month
PUSHER_APP_ID=                         # get from pusher.com dashboard
PUSHER_KEY=                            # public — used by both server and client
PUSHER_SECRET=                         # secret — server only
PUSHER_CLUSTER=ap1                     # e.g. us2, eu, ap1
